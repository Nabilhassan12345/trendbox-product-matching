# Trendbox Product Matching — environment configuration
#
# Copy this file to `.env` and adjust as needed. All variables are optional;
# the values below are the built-in defaults. `.env` is gitignored.

# ── Data paths ────────────────────────────────────────────────────────────────
# Source catalogue CSV (pipe-separated).
# TRENDBOX_DATA_CSV=data/mix_products.csv

# SQLite database location.
TRENDBOX_DB_PATH=data/matching.db

# Canonical matcher index directory (TF-IDF + FAISS + embeddings).
# pipeline.py builds here; the API loads from here on startup.
#   tfidf.joblib, embedding_index.faiss, embedding_index_meta.joblib,
#   reference_embeddings.npy
TRENDBOX_MATCHER_INDEX=data/matcher_index

# JSON report written by scripts/profile_data.py (served by GET /catalog/profile).
TRENDBOX_CATALOG_PROFILE=data/reports/catalog_profile.json

# ── Services ──────────────────────────────────────────────────────────────────
# Base URL the Streamlit UI uses to reach the API. Override when the API runs
# on another host/port (e.g. in deployment).
TRENDBOX_API_URL=http://localhost:8000

# Optional port overrides when running API/UI separately from pipeline.py.
# TRENDBOX_API_PORT=8000
# TRENDBOX_UI_PORT=8501
