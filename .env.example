# Trendbox Product Matching — environment configuration
#
# Copy this file to `.env` and adjust as needed. All variables are optional;
# the values below are the built-in defaults. `.env` is gitignored.

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
# SQLite database location.
TRENDBOX_DB_PATH=data/matching.db

# Directory holding the cached matcher index (TF-IDF + FAISS) the API loads
# on startup.
TRENDBOX_MATCHER_INDEX=data/matcher_index

# ── Frontend (Streamlit) ──────────────────────────────────────────────────────
# Base URL the Streamlit UI uses to reach the API. Override when the API runs
# on another host/port (e.g. in deployment).
TRENDBOX_API_URL=http://localhost:8000
